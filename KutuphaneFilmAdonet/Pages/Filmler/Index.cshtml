@page
@model KutuphaneFilmAdonet.Pages.Filmler.IndexModel

<h2>🎬 Film Listesi</h2>

<a class="btn btn-success mb-3" href="/Filmler/Create">
    + Film Ekle
</a>

<!-- ARAMA -->
<form method="get" class="mb-3">

    <div class="input-group">
        <input type="text"
               name="search"
               class="form-control"
               placeholder="Film adı ara..." />

        <button class="btn btn-primary" type="submit">
            Ara
        </button>
    </div>

</form>

<!-- TABLO -->
<table class="table table-hover table-bordered">

    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Film Adı</th>
            <th>Yönetmen</th>
            <th>Süre</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>

        @if (Model.FilmListesi != null && Model.FilmListesi.Count > 0)
        {
            @foreach (var item in Model.FilmListesi)
            {
                <tr>
                    <td>@item.FilmId</td>
                    <td>@item.FilmAdi</td>
                    <td>@item.Yonetmen</td>
                    <td>@item.Sure</td>

                    <td>
                        <a class="btn btn-warning btn-sm"
                           href="/Filmler/Edit?id=@item.FilmId">
                            Güncelle
                        </a>

                        <a class="btn btn-danger btn-sm"
                           href="/Filmler/Delete?id=@item.FilmId"
                           onclick="return confirm('Silmek istiyor musun?')">
                            Sil
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    Kayıt bulunamadı
                </td>
            </tr>
        }

    </tbody>

</table>