@page
@model KutuphaneFilmAdonet.Pages.Kitaplar.IndexModel

<h2 class="mb-3">📚 Kitap Listesi</h2>

<a class="btn btn-success mb-3" href="/Kitaplar/Create">
    + Yeni Kitap Ekle
</a>


<form method="get" class="mb-3">

    <div class="input-group">
        <input type="text"
               name="search"
               class="form-control"
               placeholder="Kitap adı ara..." />

        <button class="btn btn-primary" type="submit">
            Ara
        </button>
    </div>

</form>

<table class="table table-hover table-bordered">

    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Kitap Adı</th>
            <th>Yazar</th>
            <th>Sayfa Sayısı</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>

        @if (Model.KitapListesi != null && Model.KitapListesi.Count > 0)
        {
            @foreach (var item in Model.KitapListesi)
            {
                <tr>
                    <td>@item.KitapId</td>
                    <td>@item.KitapAdi</td>
                    <td>@item.Yazar</td>
                    <td>@item.SayfaSayisi</td>

                    <td>
                        <a class="btn btn-warning btn-sm"
                           href="/Kitaplar/Edit?id=@item.KitapId">
                            Güncelle
                        </a>

                        <a class="btn btn-danger btn-sm"
                           href="/Kitaplar/Delete?id=@item.KitapId"
                           onclick="return confirm('Silmek istiyor musun?')">
                            Sil
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    Kayıt bulunamadı
                </td>
            </tr>
        }

    </tbody>

</table>